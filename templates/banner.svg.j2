<svg xmlns="http://www.w3.org/2000/svg" width="800" height="180" viewBox="0 0 800 180">
{% include '_theme_youkai.svg.j2' %}
<rect width="800" height="180" fill="url(#bgGrad)" rx="4"/>

<!-- Acentos verticales -->
<rect x="0" y="0" width="6" height="180" fill="url(#accentRed)"/>
<rect x="794" y="0" width="6" height="180" fill="url(#accentRed)"/>

<!-- Patrón sutil de líneas diagonales -->
<g opacity="0.08">
  <line x1="0" y1="180" x2="180" y2="0" stroke="#E63946" stroke-width="1"/>
  <line x1="40" y1="180" x2="220" y2="0" stroke="#E63946" stroke-width="1"/>
  <line x1="80" y1="180" x2="260" y2="0" stroke="#E63946" stroke-width="1"/>
</g>

<!-- Badge -->
{% if badge %}
<g transform="translate(40, 32)">
  <rect x="0" y="0" width="{{ (badge|length * 8) + 16 }}" height="22" rx="2" fill="url(#accentRed)"/>
  <text x="8" y="16" font-family="'Inter',sans-serif" font-size="11" font-weight="800" fill="#0A0A0F" letter-spacing="2">{{ badge|svg_escape|upper }}</text>
</g>
{% endif %}

<!-- Icon + Title -->
<g transform="translate(40, {{ 78 if badge else 56 }})">
  {% if icon %}
  <text x="0" y="0" font-family="'Inter',sans-serif" font-size="32">{{ icon|svg_escape }}</text>
  {% endif %}
  {% set _tl = title|length %}{% set _ts = 32 if _tl <= 24 else (26 if _tl <= 36 else 20) %}
  <text x="{{ 52 if icon else 0 }}" y="-4" font-family="'Inter',sans-serif" font-size="{{ _ts }}" font-weight="800" fill="#F5F5F7" letter-spacing="-0.5">{{ title|truncate(50, True, '…')|svg_escape|upper }}</text>
</g>

<!-- Subtitle -->
{% if subtitle %}
<text x="{{ 92 if icon else 40 }}" y="{{ 110 if badge else 88 }}" font-family="'Inter',sans-serif" font-size="13" fill="#FFD60A" letter-spacing="0.5">{{ subtitle|truncate(72, True, '…')|svg_escape }}</text>
{% endif %}

<!-- Details -->
{% if details %}
<text x="40" y="{{ 142 if badge else 128 }}" font-family="'Inter',sans-serif" font-size="11" fill="#A0A0AA">{{ details|truncate(96, True, '…')|svg_escape }}</text>
{% endif %}

<!-- Línea decorativa inferior -->
<line x1="40" y1="160" x2="760" y2="160" stroke="#2A2A35" stroke-width="1"/>
<rect x="40" y="159" width="64" height="2" fill="url(#accentRed)"/>
</svg>
