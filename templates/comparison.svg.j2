<svg xmlns="http://www.w3.org/2000/svg" width="800" height="{{ height }}" viewBox="0 0 800 {{ height }}">
{% include '_theme_youkai.svg.j2' %}
<rect width="800" height="{{ height }}" fill="url(#bgGrad)" rx="4"/>
<rect x="0" y="0" width="800" height="2" fill="url(#accentRed)"/>

<!-- Título -->
{% set _tl = title|length %}{% set _ts = 24 if _tl <= 22 else (20 if _tl <= 32 else 16) %}
<text x="400" y="44" font-family="'Inter',sans-serif" font-size="{{ _ts }}" font-weight="700" fill="#F5F5F7" text-anchor="middle" letter-spacing="-0.5">{{ title|truncate(40, True, '…')|svg_escape }}</text>
{% if subtitle %}<text x="400" y="62" font-family="'Inter',sans-serif" font-size="11" fill="#7A7A85" text-anchor="middle" letter-spacing="2">{{ subtitle|truncate(60, True, '…')|svg_escape|upper }}</text>{% endif %}

<!-- Headers de los dos lados -->
<g>
  <!-- Left -->
  <rect x="32" y="80" width="346" height="40" rx="4" fill="#1A1419" stroke="#E63946" stroke-width="1.5"/>
  <text x="205" y="106" font-family="'Inter',sans-serif" font-size="14" font-weight="700" fill="#E63946" text-anchor="middle">{{ left.name|truncate(24, True, '…')|svg_escape }}</text>

  <!-- VS divider -->
  <text x="400" y="106" font-family="'Inter',sans-serif" font-size="14" font-weight="800" fill="#FFD60A" text-anchor="middle" letter-spacing="2">VS</text>

  <!-- Right -->
  <rect x="422" y="80" width="346" height="40" rx="4" fill="#141A1A" stroke="#06FFA5" stroke-width="1.5"/>
  <text x="595" y="106" font-family="'Inter',sans-serif" font-size="14" font-weight="700" fill="#06FFA5" text-anchor="middle">{{ right.name|truncate(24, True, '…')|svg_escape }}</text>
</g>

<!-- Stats comparativos -->
{% for s in stat_labels %}
<g transform="translate(0, {{ s._y }})">
  <!-- Label -->
  <text x="400" y="-8" font-family="'Inter',sans-serif" font-size="10" fill="#A0A0AA" text-anchor="middle" letter-spacing="2">{{ s.label|svg_escape|upper }}</text>

  <!-- Left bar (de derecha a izquierda) -->
  <rect x="{{ 378 - s._left_px }}" y="0" width="{{ s._left_px }}" height="14" rx="2" fill="url(#accentRed)"/>
  <text x="368" y="11" font-family="'Inter',sans-serif" font-size="11" font-weight="700" fill="#F5F5F7" text-anchor="end">{{ s.left_value|int }}</text>

  <!-- Centro divisor -->
  <rect x="398" y="-2" width="4" height="18" fill="#2A2A35"/>

  <!-- Right bar -->
  <rect x="422" y="0" width="{{ s._right_px }}" height="14" rx="2" fill="url(#accentCyan)"/>
  <text x="432" y="11" font-family="'Inter',sans-serif" font-size="11" font-weight="700" fill="#F5F5F7">{{ s.right_value|int }}</text>
</g>
{% endfor %}

<!-- Footer -->
<text x="768" y="{{ height - 14 }}" font-family="'Inter',sans-serif" font-size="9" fill="#4A4A55" text-anchor="end" letter-spacing="3">YOUKAI · COMPARISON</text>
</svg>
