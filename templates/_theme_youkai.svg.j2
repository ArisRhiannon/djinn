<defs>
  <!-- Youkai theme: cyberpunk urbano minimalista (ZZZ aesthetic) -->
  <!-- Fondos: negro profundo. Acentos: rojo carmesí (Youkai), amarillo neón (HUD), cyan (datos). -->
  <linearGradient id="bgGrad" x1="0%" y1="0%" x2="0%" y2="100%">
    <stop offset="0%" stop-color="#13131A"/>
    <stop offset="100%" stop-color="#0A0A0F"/>
  </linearGradient>
  <linearGradient id="accentRed" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" stop-color="#E63946"/>
    <stop offset="100%" stop-color="#DC143C"/>
  </linearGradient>
  <linearGradient id="accentYellow" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" stop-color="#FFD60A"/>
    <stop offset="100%" stop-color="#F5B800"/>
  </linearGradient>
  <linearGradient id="accentCyan" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" stop-color="#06FFA5"/>
    <stop offset="100%" stop-color="#00D4AA"/>
  </linearGradient>
  <filter id="glowRed" x="-50%" y="-50%" width="200%" height="200%">
    <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
    <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
  </filter>
</defs>
