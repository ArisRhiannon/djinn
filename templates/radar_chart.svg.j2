<svg xmlns="http://www.w3.org/2000/svg" width="600" height="500" viewBox="0 0 600 500">
{% include '_theme_youkai.svg.j2' %}
<rect width="600" height="500" fill="url(#bgGrad)" rx="4"/>
<rect x="0" y="0" width="600" height="2" fill="url(#accentRed)"/>

<!-- Título -->
{% set _tl = title|length %}{% set _ts = 22 if _tl <= 22 else (18 if _tl <= 32 else 16) %}
<text x="300" y="44" font-family="'Inter',sans-serif" font-size="{{ _ts }}" font-weight="700" fill="#F5F5F7" text-anchor="middle" letter-spacing="-0.5">{{ title|truncate(40, True, '…')|svg_escape }}</text>
{% if subtitle %}<text x="300" y="64" font-family="'Inter',sans-serif" font-size="11" fill="#7A7A85" text-anchor="middle" letter-spacing="2">{{ subtitle|truncate(60, True, '…')|svg_escape|upper }}</text>{% endif %}

<line x1="32" y1="80" x2="568" y2="80" stroke="#2A2A35" stroke-width="1"/>
<rect x="32" y="79" width="48" height="2" fill="url(#accentRed)"/>

<!-- Hexágono base 100% -->
<g stroke="#2A2A35" fill="none">
{% for level in [25, 50, 75, 100] %}
{% set scale = level / 100.0 %}
<polygon points="
{% for axis in axes[:6] %}
{% set ang = -1.5708 + (loop.index0 * 1.0472) %}
{% set bx = 300 + (140 * scale) * (loop.index0|float - loop.index0|float)|float %}
{% endfor %}
{{ 300 + (140 * scale) * 0 }},{{ 225 - (140 * scale) }}
{{ 300 + (140 * scale) * 0.866 }},{{ 225 - (140 * scale) * 0.5 }}
{{ 300 + (140 * scale) * 0.866 }},{{ 225 + (140 * scale) * 0.5 }}
{{ 300 + (140 * scale) * 0 }},{{ 225 + (140 * scale) }}
{{ 300 - (140 * scale) * 0.866 }},{{ 225 + (140 * scale) * 0.5 }}
{{ 300 - (140 * scale) * 0.866 }},{{ 225 - (140 * scale) * 0.5 }}
" stroke-width="0.5" opacity="{{ 0.3 + (level / 200.0) }}"/>
{% endfor %}
</g>

<!-- Líneas de ejes -->
<g stroke="#2A2A35" stroke-width="0.5">
{% for axis in axes[:6] %}
<line x1="300" y1="225" x2="{{ axis._bx }}" y2="{{ axis._by }}"/>
{% endfor %}
</g>

<!-- Polígono de valores -->
<polygon points="
{% for axis in axes[:6] %}
{{ axis._vx }},{{ axis._vy }}
{% endfor %}
" fill="#E63946" fill-opacity="0.25" stroke="#E63946" stroke-width="2"/>

<!-- Puntos en cada vértice -->
{% for axis in axes[:6] %}
<circle cx="{{ axis._vx }}" cy="{{ axis._vy }}" r="4" fill="#FFD60A" stroke="#E63946" stroke-width="1.5"/>
{% endfor %}

<!-- Labels -->
{% for axis in axes[:6] %}
<g>
  <text x="{{ axis._lx }}" y="{{ axis._ly }}" font-family="'Inter',sans-serif" font-size="11" font-weight="600" fill="#E0E0E5" text-anchor="middle">{{ axis.label|truncate(12, True, '…')|svg_escape|upper }}</text>
  <text x="{{ axis._lx }}" y="{{ axis._ly + 14 }}" font-family="'Inter',sans-serif" font-size="10" font-weight="700" fill="#FFD60A" text-anchor="middle">{{ axis.value|int }}</text>
</g>
{% endfor %}

<!-- Footer -->
<text x="568" y="486" font-family="'Inter',sans-serif" font-size="9" fill="#4A4A55" text-anchor="end" letter-spacing="3">YOUKAI · RADAR</text>
</svg>
