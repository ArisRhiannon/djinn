<svg xmlns="http://www.w3.org/2000/svg" width="800" height="{{ height }}" viewBox="0 0 800 {{ height }}">
{% include '_theme_youkai.svg.j2' %}
<rect width="800" height="{{ height }}" fill="url(#bgGrad)" rx="4"/>
<rect x="0" y="0" width="800" height="2" fill="url(#accentRed)"/>

<!-- Título -->
{% set _tl = title|length %}{% set _ts = 24 if _tl <= 22 else (20 if _tl <= 32 else 16) %}
<text x="32" y="44" font-family="'Inter',sans-serif" font-size="{{ _ts }}" font-weight="700" fill="#F5F5F7" letter-spacing="-0.5">{{ title|truncate(40, True, '…')|svg_escape }}</text>
{% if subtitle %}<text x="32" y="64" font-family="'Inter',sans-serif" font-size="11" fill="#7A7A85" letter-spacing="2">{{ subtitle|truncate(60, True, '…')|svg_escape|upper }}</text>{% endif %}

<line x1="32" y1="80" x2="768" y2="80" stroke="#2A2A35" stroke-width="1"/>
<rect x="32" y="79" width="48" height="2" fill="url(#accentRed)"/>

<!-- Default colors si segments no traen color -->
{% set default_colors = ['#E63946', '#FFD60A', '#06FFA5', '#06B6D4', '#A855F7', '#EC4899', '#7A7A85'] %}

<!-- Donut segments -->
<g>
{% for seg in segments %}
{% set scolor = seg.color|default(default_colors[loop.index0 % default_colors|length]) %}
<path d="{{ seg._path }}" fill="{{ scolor }}" opacity="0.9"/>
{% endfor %}
<!-- Hole en el centro -->
<circle cx="400" cy="280" r="80" fill="#0A0A0F"/>
<!-- Borde sutil del donut -->
<circle cx="400" cy="280" r="120" fill="none" stroke="#2A2A35" stroke-width="1"/>
<circle cx="400" cy="280" r="80" fill="none" stroke="#2A2A35" stroke-width="1"/>
</g>

<!-- Centro: total -->
<text x="400" y="276" font-family="'Inter',sans-serif" font-size="32" font-weight="800" fill="#F5F5F7" text-anchor="middle">{{ center_text|svg_escape }}</text>
<text x="400" y="298" font-family="'Inter',sans-serif" font-size="10" fill="#7A7A85" text-anchor="middle" letter-spacing="3">{{ center_label|svg_escape|upper }}</text>

<!-- Legend (lado derecho) -->
{% set legend_x = 580 %}
{% set legend_y_start = 140 %}
{% for seg in segments %}
{% set scolor = seg.color|default(default_colors[loop.index0 % default_colors|length]) %}
<g transform="translate({{ legend_x }}, {{ legend_y_start + loop.index0 * 32 }})">
  <rect x="0" y="0" width="12" height="12" rx="2" fill="{{ scolor }}"/>
  <text x="20" y="10" font-family="'Inter',sans-serif" font-size="11" font-weight="500" fill="#E0E0E5">{{ seg.label|truncate(16, True, '…')|svg_escape }}</text>
  <text x="160" y="10" font-family="'Inter',sans-serif" font-size="11" font-weight="700" fill="{{ scolor }}" text-anchor="end">{{ seg._pct }}</text>
</g>
{% endfor %}

<!-- Footer -->
<text x="768" y="{{ height - 14 }}" font-family="'Inter',sans-serif" font-size="9" fill="#4A4A55" text-anchor="end" letter-spacing="3">YOUKAI · {{ segments|length }} SEGMENTOS</text>
</svg>
