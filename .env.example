# ── Djinn Agent — Variables de entorno ──────────────────────────────────
# Copia este archivo como .env y rellena los valores.
# NUNCA commitees .env al repositorio.

# ── Discord ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=

# ── API key interna del servidor HTTP de Djinn (genera una aleatoria) ───
DJINN_API_KEY=

# ── LLM Provider ─────────────────────────────────────────────────────────
# Opciones: google | openrouter | custom | kiro | nim
LLM_PROVIDER=google

# ── Google AI Studio ──────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_MODEL_NAME=gemini-2.0-flash

# ── OpenRouter (opcional) ─────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL_NAME=google/gemma-3-27b-it:free

# ── Custom provider (OpenAI-compatible) ───────────────────────────────────
CUSTOM_BASE_URL=http://localhost:5001/v1
CUSTOM_API_KEY=
CUSTOM_MODEL_NAME=my-local-model

# ── Owner del servidor (tu User ID de Discord) ────────────────────────────
# Si lo defines, el bot te tratará como administrador supremo.
OWNER_USER_ID=

# ── Base de datos ─────────────────────────────────────────────────────────
DB_PATH=db/djinn.db

# ── Embeddings ────────────────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_CACHE_DIR=models/embed

# ── Logging ───────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
DJINN_LOG_LEVEL=INFO

# ── Soul file ─────────────────────────────────────────────────────────────
# Ruta al archivo de identidad configurable del bot.
SOUL_PATH=soul.md
